# =====================================================
# MenuKH
# =====================================================

Options -Indexes

DirectoryIndex index.php

<IfModule mod_rewrite.c>

RewriteEngine On

RewriteBase /MenuKH/

# Existing File
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Friendly URL (Phase 2)
# RewriteRule ^login/?$ login.php [L,QSA]
# RewriteRule ^register/?$ register.php [L,QSA]

</IfModule>

# -----------------------------------------------------
# Protect Sensitive Files
# -----------------------------------------------------

<FilesMatch "(\.json|\.log|\.env|composer\.json|composer\.lock)$">
    Require all denied
</FilesMatch>

<FilesMatch "^(\.htaccess)$">
    Require all denied
</FilesMatch>

# Disable Server Signature
ServerSignature Off